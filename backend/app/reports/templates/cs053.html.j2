<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<title>CS053 — {{ site_name }} — {{ insp_date }}</title>
<style>
  {% include '_spencer_design_system.css.j2' %}

  /* ======================================================================
     CS053-specific CSS below this line.
     Everything that appears in the design system partial (tokens, page
     setup, id-grid, validity-block, section-head/body, signature block,
     state pill, data quality banner, provenance) is inherited from there.
     ====================================================================== */

  /* ---------- Summary strip (CS053-specific dashboard cells) ----------
     border-spacing: 0 so the strip's left/right edges line up flush with
     the identifier grid and category boxes above/below. Cells touch each
     other but are visually separated by their own 1px Spencer Blue border. */
  .summary-strip {
    display: table;
    width: 100%;
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0;
    margin: 8pt 0;
  }
  .summary-cell {
    display: table-cell;
    padding: 7pt 8pt;
    text-align: center;
    border: 1px solid var(--divider);
    background: var(--bg-alt);
    width: 20%;
  }
  .summary-cell + .summary-cell { border-left: none; }
  .summary-cell .sc-label {
    font-size: 7.5pt;
    letter-spacing: 0.4px;
    color: var(--text-muted);
    font-weight: 600;
  }
  .summary-cell .sc-value {
    font-size: 18pt;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    margin-top: 2pt;
  }
  .summary-cell.green .sc-value { color: var(--ok-green); }
  .summary-cell.red   .sc-value { color: var(--err-red); }
  .summary-cell.na    .sc-value { color: var(--na-grey); }

  /* ---------- Categories (CS053-specific inspection structure) ---------- */
  .category { margin-bottom: 6pt; break-inside: avoid-page; page-break-inside: avoid; }
  .category-header {
    display: table;
    width: 100%;
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0;
    background: var(--spencer-blue);
    color: #fff;
  }
  .category-header > div { display: table-cell; vertical-align: middle; padding: 5pt 10pt; }
  .cat-num {
    font-size: 13pt;
    font-weight: 700;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.35);
    width: 36px;
  }
  .cat-title { font-size: 10.5pt; font-weight: 700; letter-spacing: 0.2px; }
  .cat-counts { width: 230px; text-align: right; padding-right: 10pt !important; white-space: nowrap; }
  .count-chip {
    display: inline-block;
    margin-left: 4px;
    padding: 2px 7px;
    border-radius: 10px;
    font-size: 7.5pt;
    font-weight: 700;
    letter-spacing: 0.3px;
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
  }
  .count-chip .cc-num { font-size: 9pt; margin-right: 4px; }
  .count-chip .cc-lbl { font-size: 7pt; opacity: 0.9; }
  .count-chip.count-green { background: var(--ok-green); border-color: var(--ok-green); }
  .count-chip.count-red   { background: var(--err-red);  border-color: var(--err-red); }
  .count-chip.count-na    { background: var(--na-grey);  border-color: var(--na-grey); }
  .count-chip.count-blank { background: transparent; border: 1px dashed rgba(255,255,255,0.5); color: rgba(255,255,255,0.7); }
  .count-chip.count-zero  { opacity: 0.35; }

  .category-items { border: 1px solid var(--divider); border-top: none; }
  .item-row {
    display: table;
    width: 100%;
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0;
    border-bottom: 1px solid var(--divider-soft);
  }
  .category-items > div:last-child { border-bottom: none; }
  .item-row:nth-child(even) { background: var(--bg-alt); }
  .item-row > div { display: table-cell; vertical-align: middle; padding: 4pt 10pt; }
  .item-num { width: 44px; font-weight: 700; font-size: 9pt; color: var(--spencer-blue); }
  .item-body { font-size: 9pt; line-height: 1.35; }
  .item-photo { width: 170px; text-align: right; vertical-align: middle; padding: 6pt 8pt !important; }
  .item-photo img { max-width: 150px; max-height: 105px; display: inline-block; object-fit: cover; }
  .item-photo .photo-missing {
    display: inline-block;
    width: 150px;
    height: 105px;
    border: 1px dashed var(--divider);
    background: var(--bg-alt);
    color: var(--spencer-blue);
    text-align: center;
    font-size: 7pt;
    padding-top: 42px;
    position: relative;
  }
  .photo-count-more { font-size: 7pt; color: var(--spencer-blue); margin-top: 3pt; font-weight: 600; }
  /* Widened from 80px + removed the 14pt right-padding override so the
     52px min-width state pill fits comfortably without overflowing the
     category-items right border. */
  .item-state { width: 100px; text-align: right; }

  .finding-inline {
    margin-top: 4pt;
    padding: 3pt 6pt;
    background: #FDECEA;
    border-left: 2px solid var(--err-red);
    font-size: 8pt;
  }
  .finding-inline > span { margin-right: 8pt; }
  .finding-tag { font-weight: 700; color: var(--err-red); }
  .finding-subject { font-weight: 700; }
  .finding-sev {
    background: var(--err-red); color: #fff;
    padding: 1px 6px; border-radius: 2px; font-size: 7.5pt;
  }
  .finding-assignee { color: var(--text-muted); }
  .finding-closed { color: var(--ok-green); font-weight: 600; }
  .finding-open { color: var(--err-red); font-weight: 700; font-size: 7.5pt; }
  .finding-evidence { font-size: 7.5pt; color: var(--text-muted); font-style: italic; }

  .ph-no {
    position: absolute;
    top: 4px; left: 4px;
    background: var(--spencer-blue);
    color: #fff;
    font-size: 7pt;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 2px;
  }

  /* ---------- Findings section (CS053-specific) ----------
     Two layers: a compact summary table (one row per finding) followed
     by expanded cards (full metadata, description, resolution strip,
     evidence photos). */
  .findings-section-head {
    background: var(--spencer-blue);
    color: #fff;
    padding: 8pt 12pt;
    font-size: 11pt;
    font-weight: 700;
    margin-top: 16pt;
    margin-bottom: 12pt;
  }

  /* Summary table */
  .findings-summary-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 8.5pt;
    margin-bottom: 16pt;
  }
  .findings-summary-table th {
    background: var(--bg-alt);
    border: 1px solid var(--divider);
    padding: 5pt 8pt;
    font-weight: 700;
    text-align: left;
    color: var(--spencer-blue);
    font-size: 8pt;
  }
  .findings-summary-table td {
    border: 1px solid var(--divider);
    padding: 5pt 8pt;
    vertical-align: top;
  }
  .fs-hdr { font-weight: 700; }
  .fs-item { color: var(--text-muted); font-size: 8pt; margin-top: 2pt; }
  .fs-meta { font-size: 7.5pt; color: var(--text-muted); margin-top: 1pt; }
  .fs-none { text-align: center; color: var(--ok-green); font-weight: 600; padding: 12pt 0; }
  .fs-closed { color: var(--ok-green); font-weight: 600; }
  .fs-open { color: #B7770D; font-weight: 600; }

  /* Expanded finding cards */
  .finding-card { border: 1px solid var(--divider); margin-bottom: 14pt; page-break-inside: avoid; }
  .finding-card-header {
    background: var(--spencer-blue);
    color: #fff;
    padding: 8pt 12pt;
    display: table;
    width: 100%;
    table-layout: fixed;
  }
  .finding-card-header > div { display: table-cell; vertical-align: middle; }
  .fc-num { font-size: 14pt; font-weight: 700; width: 60pt; }
  .fc-subject { font-size: 10pt; font-weight: 600; line-height: 1.3; }
  .fc-sev {
    width: 70pt;
    text-align: right;
    font-size: 8pt;
    font-weight: 700;
  }
  .fc-sev span {
    display: inline-block;
    padding: 3pt 10pt;
    border-radius: 3px;
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.4);
  }
  .fc-sev span.sev5 { background: var(--err-red); border-color: var(--err-red); }
  .fc-sev span.sev4 { background: #E07B00; border-color: #E07B00; }
  .fc-sev span.sev3 { background: #B7770D; border-color: #B7770D; }

  .finding-meta-grid {
    display: table;
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
  }
  .fmg-row { display: table-row; }
  .fmg-cell {
    display: table-cell;
    width: 50%;
    padding: 5pt 10pt;
    border-right: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
    font-size: 8.5pt;
  }
  .fmg-cell:nth-child(even) { border-right: none; }
  .fmg-label {
    color: var(--text-muted);
    font-weight: 600;
    font-size: 7.5pt;
    text-transform: uppercase;
    margin-bottom: 1pt;
  }
  .fmg-value { font-weight: 600; }
  .fmg-closed { color: var(--ok-green); font-weight: 600; }
  .fmg-open { color: #B7770D; font-weight: 600; }

  .finding-description {
    padding: 8pt 10pt;
    font-size: 9pt;
    line-height: 1.5;
    border-bottom: 1px solid var(--divider);
    background: var(--bg-alt);
  }
  .fd-label {
    font-weight: 700;
    font-size: 7.5pt;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 3pt;
  }

  .resolution-strip {
    padding: 5pt 8pt;
    background: #EAF4EE;
    border-left: 3px solid var(--ok-green);
    font-size: 8pt;
    border-bottom: 1px solid var(--divider);
  }
  .res-label { font-weight: 700; color: var(--ok-green); margin-right: 4pt; }

  /* page-break-inside: avoid keeps the "EVIDENCE PHOTOS (N)" label glued
     to its photos — prevents an orphan label at the bottom of one page
     with the first photo pushed to the next. If the block is too tall
     to fit on the current page, WeasyPrint moves the whole unit. */
  .finding-photos { padding: 8pt 10pt; page-break-inside: avoid; }
  .fp-cell { page-break-inside: avoid; }
  .fp-label {
    font-weight: 700;
    font-size: 7.5pt;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6pt;
  }
  /* The image box auto-sizes to the photo's natural aspect within max
     constraints — so landscape photos go wide and portraits go tall.
     Cell wraps the photo+caption and centres horizontally in the card.
     Removed the old double-border treatment (cell + image both had a
     frame) — only .fpc-img carries a visible border now. */
  .fp-row { display: block; text-align: center; }
  .fp-cell {
    display: inline-block;
    vertical-align: top;
    margin: 0 0 12pt 0;
    text-align: left;
    font-size: 7.5pt;
    line-height: 1.3;
    max-width: 100%;
  }
  .fp-cell:last-child { margin-bottom: 0; }
  .fpc-img {
    display: block;
    background: var(--bg-alt);
    border: 1px solid var(--divider);
    position: relative;
    line-height: 0;
    font-size: 0;
  }
  /* Max-width caps the photo at the card content area; max-height caps
     a tall portrait from taking the whole page. Whichever limit binds
     first wins, so a landscape photo lands at 186mm × ~140mm and a
     portrait at ~135mm × 180mm. No cropping either way. */
  .fpc-img img {
    display: block;
    max-width: 186mm;
    max-height: 180mm;
  }
  .fpc-missing {
    display: block;
    padding: 40mm 20mm;
    font-size: 9pt;
    line-height: 1.2;
    color: var(--text-muted);
    text-align: center;
  }
  /* z-index keeps the chips above the image in WeasyPrint's stacking. */
  .fpc-badge {
    position: absolute;
    top: 6pt;
    left: 6pt;
    background: var(--spencer-blue);
    color: #fff;
    font-size: 8pt;
    font-weight: 700;
    font-family: monospace;
    padding: 3pt 7pt;
    border-radius: 2px;
    line-height: 1.2;
    z-index: 2;
  }
  .fpc-src {
    position: absolute;
    top: 6pt;
    right: 6pt;
    background: #FDECEA;
    color: var(--err-red);
    border: 1px solid var(--err-red);
    font-size: 7pt;
    font-weight: 700;
    padding: 2pt 6pt;
    border-radius: 2px;
    line-height: 1.2;
    z-index: 2;
  }
  .fpc-caption {
    padding: 4pt 2pt 0 2pt;
    font-size: 7.5pt;
    line-height: 1.3;
    color: var(--text-muted);
    text-align: right;
    font-style: italic;
  }

  /* ---------- Signoff block + close-call note (CS053-specific) ---------- */
  .signoff-block {
    margin-top: 14pt;
    border: 1px solid var(--divider);
    padding: 10pt;
    display: table;
    width: 100%;
  }
  .signoff-block > div { display: table-cell; vertical-align: middle; }
  .signoff-name { font-weight: 700; }
  .signoff-hint { font-size: 8pt; color: var(--text-muted); margin-top: 4pt; }
  .closecall-note {
    margin-top: 8pt;
    padding: 8pt 10pt;
    background: var(--bg-alt);
    font-size: 8.5pt;
    border-left: 3px solid var(--spencer-blue);
  }

  /* ---------- Photo appendix (CS053-specific documented deviation) ---------- */
  .section-break { page-break-before: always; }
  .page-header-sm {
    background: var(--spencer-blue);
    color: #fff;
    padding: 6pt 10pt;
    font-weight: 700;
    font-size: 10pt;
    margin-bottom: 10pt;
  }
  .photo-cell-full {
    border: 1px solid var(--divider);
    padding: 8pt;
    margin-bottom: 8pt;
    break-inside: avoid-page;
    page-break-inside: avoid;
  }
  .pc-full-hdr {
    display: table;
    width: 100%;
    padding-bottom: 6pt;
    border-bottom: 2px solid var(--spencer-blue);
    margin-bottom: 6pt;
  }
  .pc-full-hdr > span { display: table-cell; vertical-align: middle; }
  .pc-full-no {
    background: var(--spencer-blue);
    color: #fff;
    font-size: 11pt;
    font-weight: 700;
    padding: 4pt 12pt;
    border-radius: 2px;
    width: 110px;
  }
  .pc-full-item { font-size: 10pt; font-weight: 700; padding-left: 12pt; padding-right: 12pt; }
  .pc-full-img {
    background: var(--bg-alt);
    border: 1px solid var(--divider);
    height: 100mm;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .pc-full-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .pc-full-img .photo-missing-large { color: var(--spencer-blue); font-size: 10pt; font-weight: 700; }
  .pc-full-img .ph-no { top: 8px; left: 8px; font-size: 10pt; padding: 3px 9px; }
  .pc-full-meta { margin-top: 6pt; font-size: 8.5pt; color: var(--text-muted); text-align: right; font-style: italic; }
  .pc-src {
    display: inline-block;
    padding: 2pt 8pt;
    border-radius: 2px;
    font-size: 7.5pt;
    font-weight: 700;
    white-space: nowrap;
  }
  .pc-src-inspection { background: var(--bg-alt); color: var(--spencer-blue); border: 1px solid var(--spencer-blue); }
  .pc-src-evidence   { background: #FDECEA;       color: var(--err-red);     border: 1px solid var(--err-red); }
</style>
</head>
<body>

<!-- Running footer (two-column per design system §10). -->
<div class="page-footer">
  <div class="row">
    <div class="left">
      <div class="line1"><strong>Dalux Field</strong> &middot; Form No. CS 053 &middot; Issue No. 18 (rev) &middot; Revision date 16/04/2026</div>
      <div>SOS location: Internal audits &rarr; Weekly safety, health, environmental and quality inspection (CS053)</div>
    </div>
    <div class="right">
      <div class="email">{{ footer_email or '(email not on file)' }}</div>
      <div class="pageno"></div>
    </div>
  </div>
</div>

<!-- Page 1 header band -->
<div class="header-band">
  <div class="cell qr-cell">
    {% if qr_data_uri %}<img src="{{ qr_data_uri }}" alt="QR">{% endif %}
  </div>
  <div class="cell title-cell">
    <h1 class="doc-title">CS053 &mdash; Weekly safety, health, environmental and quality inspection</h1>
  </div>
  <div class="cell logo-cell">
    {% if logo_data_uri %}<img src="{{ logo_data_uri }}" alt="Spencer">{% endif %}
  </div>
</div>

<!-- Identifier grid (design system §2). Project no. is locked to (1,1). -->
<table class="id-grid">
  <tr>
    <td>
      <div class="id-label">Project no. / SOS</div>
      <div class="id-value mono {{ project_num|size_class(mono=True) }}">{{ project_num }}</div>
    </td>
    <td>
      <div class="id-label">Site</div>
      <div class="id-value {{ site_name|size_class }}">{{ site_name }}</div>
    </td>
    <td>
      <div class="id-label">Form no. (Dalux)</div>
      <div class="id-value mono {{ form_number|size_class(mono=True) }}">{{ form_number }}</div>
    </td>
  </tr>
  <tr>
    <td>
      <div class="id-label">Inspection by</div>
      <div class="id-value {{ inspector|size_class }}">{{ inspector }}</div>
    </td>
    <td>
      <div class="id-label">Inspection date</div>
      <div class="id-value mono {{ insp_date|size_class(mono=True) }}">{{ insp_date or '&mdash;' }}</div>
    </td>
    <td>
      <div class="id-label">Status</div>
      <div class="id-value"><span class="status-chip {{ status_class }}">{{ status_label }}</span></div>
    </td>
  </tr>
</table>

<!-- Inspection context (CS053-specific narrative metadata) -->
<div class="section">
  <div class="section-head">
    Inspection context
    <span class="sub">Accompanied personnel, last-inspection reference, subcontractors observed</span>
  </div>
  <div class="section-body no-pad">
    <table class="narrative-table">
      <tr>
        <td class="label">Accompanied by</td>
        <td class="content">{{ accompanied|join(', ') if accompanied else '&mdash;' }}</td>
      </tr>
      <tr>
        <td class="label">Date of last inspection</td>
        <td class="content">{{ last_insp or '&mdash;' }}</td>
      </tr>
      <tr>
        <td class="label">Last actions closed?</td>
        <td class="content">{{ actions_closed or '&mdash;' }}</td>
      </tr>
      <tr>
        <td class="label">Subcontractors checked</td>
        <td class="content">{{ companies|join(', ') if companies else '&mdash;' }}</td>
      </tr>
    </table>
  </div>
</div>

<!-- Summary strip (CS053-specific dashboard) -->
<div class="summary-strip">
  <div class="summary-cell"><div class="sc-label">Items inspected</div><div class="sc-value">{{ total_items }}</div></div>
  <div class="summary-cell green"><div class="sc-label">Green</div><div class="sc-value">{{ total_green }}</div></div>
  <div class="summary-cell red"><div class="sc-label">Red</div><div class="sc-value">{{ total_red }}</div></div>
  <div class="summary-cell na"><div class="sc-label">N/A</div><div class="sc-value">{{ total_na }}</div></div>
  <div class="summary-cell"><div class="sc-label">Photos</div><div class="sc-value">{{ total_photos }}</div></div>
</div>

{% for cat in categories %}
<section class="category">
  <div class="category-header">
    <div class="cat-num">{{ cat.num }}</div>
    <div class="cat-title">{{ cat.title }}</div>
    <div class="cat-counts">
      <span class="count-chip count-green {% if cat.green == 0 %}count-zero{% endif %}"><span class="cc-num">{{ cat.green }}</span><span class="cc-lbl">Green</span></span>
      <span class="count-chip count-red {% if cat.red == 0 %}count-zero{% endif %}"><span class="cc-num">{{ cat.red }}</span><span class="cc-lbl">Red</span></span>
      <span class="count-chip count-na {% if cat.na == 0 %}count-zero{% endif %}"><span class="cc-num">{{ cat.na }}</span><span class="cc-lbl">N/A</span></span>
      {% if cat.blank > 0 %}<span class="count-chip count-blank"><span class="cc-num">{{ cat.blank }}</span><span class="cc-lbl">&mdash;</span></span>{% endif %}
    </div>
  </div>
  <div class="category-items">
    {% for item in cat["items"] %}
    <div class="item-row">
      <div class="item-num">{{ item.num }}</div>
      <div class="item-body">
        <div class="item-title">{{ item.title }}</div>
        {% for f in item.findings %}
        <div class="finding-inline">
          <span class="finding-tag">{{ f.number }}</span>
          <span class="finding-subject">{{ f.subject }}</span>
          <span class="finding-sev">Severity {{ f.severity }}</span>
          <span class="finding-assignee">&rarr; {{ f.assignee }}</span>
          {% if f.closed_date %}<span class="finding-closed">Closed {{ f.closed_date }}</span>
          {% else %}<span class="finding-open">Open</span>{% endif %}
          {% if f.evidence_nos %}<span class="finding-evidence">Evidence: {{ f.evidence_nos|join(', ') }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>
      <div class="item-photo">
        {% if item.photos %}
          {% set p = item.photos[0] %}
          {% if p.local_src %}<img src="{{ p.local_src }}" alt="Photo #{{ p.photo_no }}">{% else %}<div class="photo-missing"><div class="ph-no">#{{ p.photo_no }}</div>Photo<br>{{ p.attachmentId[:8] }}</div>{% endif %}
          {% if item.photos|length > 1 %}<div class="photo-count-more">+{{ item.photos|length - 1 }} more</div>{% endif %}
        {% endif %}
      </div>
      <div class="item-state">
        {% set pc = {'Green': 'yes', 'Red': 'no', 'N/A': 'na'}.get(item.state, 'blank') %}
        <span class="state-pill {{ pc }}">{{ item.state or '—' }}</span>
      </div>
    </div>
    {% endfor %}
  </div>
</section>
{% endfor %}

{# --- Findings & actions: summary table + expanded cards --- #}
{% if findings %}
<div class="findings-section-head">
  Findings &amp; Actions &mdash; {{ findings|length }} issue{% if findings|length != 1 %}s{% endif %} raised
</div>

<table class="findings-summary-table">
  <thead>
    <tr>
      <th style="width:22pt">No.</th>
      <th>Finding</th>
      <th>Action taken</th>
      <th>Who by</th>
      <th>Closed</th>
      <th>Close call</th>
    </tr>
  </thead>
  <tbody>
    {% for f in findings %}
    <tr>
      <td style="text-align:center;font-weight:700">{{ loop.index }}</td>
      <td>
        <div class="fs-hdr">{{ f.number }} &mdash; {{ f.subject }}{% if f.evidence_nos %} (Evidence: {{ f.evidence_nos|join(', ') }}){% endif %}</div>
        <div class="fs-item">Item: {{ f.item_ref }}</div>
        <div class="fs-meta">Severity: {{ f.severity }}{% if f.subcategory %} &middot; {{ f.subcategory }}{% endif %}</div>
      </td>
      <td>{{ f.resolution_message or '(see Dalux task record)' }}</td>
      <td>{{ f.assignee }}</td>
      <td>{% if f.closed_date %}<span class="fs-closed">&#10003; {{ f.closed_date }}</span>{% else %}<span class="fs-open">Open</span>{% endif %}</td>
      <td>&mdash;</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{% for f in findings %}
<div class="finding-card">
  <div class="finding-card-header">
    <div class="fc-num">{{ f.number }}</div>
    <div class="fc-subject">{{ f.subject }}</div>
    <div class="fc-sev"><span class="{{ f.sev_class }}">Severity {{ f.severity }}</span></div>
  </div>

  <div class="finding-meta-grid">
    <div class="fmg-row">
      <div class="fmg-cell"><div class="fmg-label">Checklist item</div><div class="fmg-value">{{ f.item_ref or '—' }}</div></div>
      <div class="fmg-cell"><div class="fmg-label">Subcategory</div><div class="fmg-value">{{ f.subcategory or '—' }}</div></div>
    </div>
    <div class="fmg-row">
      <div class="fmg-cell"><div class="fmg-label">Raised by</div><div class="fmg-value">{{ f.raised_by or '—' }}</div></div>
      <div class="fmg-cell"><div class="fmg-label">Assigned to</div><div class="fmg-value">{{ f.assignee or '—' }}</div></div>
    </div>
    <div class="fmg-row">
      <div class="fmg-cell"><div class="fmg-label">Date raised</div><div class="fmg-value">{{ f.date_raised or '—' }}</div></div>
      <div class="fmg-cell"><div class="fmg-label">Deadline</div><div class="fmg-value">{{ f.deadline or '—' }}</div></div>
    </div>
    <div class="fmg-row">
      <div class="fmg-cell"><div class="fmg-label">Work package</div><div class="fmg-value">{{ f.work_package or '—' }}</div></div>
      <div class="fmg-cell">
        <div class="fmg-label">Status</div>
        <div class="fmg-value">
          {% if f.closed_date %}<span class="fmg-closed">&#10003; Approved / Closed &mdash; {{ f.closed_date }}</span>
          {% else %}<span class="fmg-open">Open</span>{% endif %}
        </div>
      </div>
    </div>
  </div>

  {% if f.description %}
  <div class="finding-description">
    <div class="fd-label">Description</div>
    {{ f.description }}
  </div>
  {% endif %}

  {% if f.resolution_message %}
  <div class="resolution-strip">
    <span class="res-label">Resolution{% if f.resolution_date %} ({{ f.resolution_date }}{% if f.resolution_by %} &mdash; {{ f.resolution_by }}{% endif %}){% endif %}:</span>
    {{ f.resolution_message }}
  </div>
  {% endif %}

  {% if f.evidence %}
  <div class="finding-photos">
    <div class="fp-label">Evidence photos ({{ f.evidence|length }})</div>
    <div class="fp-row">
      {% for e in f.evidence %}
      <div class="fp-cell">
        <div class="fpc-img">
          {% if e.local_src %}
            <img src="{{ e.local_src }}" alt="Photo #{{ e.photo_no }}">
          {% else %}
            <div class="fpc-missing">Photo #{{ e.photo_no }}<br>not downloaded</div>
          {% endif %}
          <div class="fpc-badge">#{{ e.photo_no }}</div>
          <div class="fpc-src">EVIDENCE</div>
        </div>
        <div class="fpc-caption">{{ f.number }} &middot; Photo {{ loop.index }} of {{ f.evidence|length }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

</div>
{% endfor %}
{% else %}
<div style="text-align:center;color:var(--ok-green);font-weight:600;padding:14pt 0;">
  No findings raised during this inspection.
</div>
{% endif %}

<div class="closecall-note">Please confirm that all Close Calls identified in this report have been uploaded onto the Close Call System (https://thespencergroup.co.uk/closecall/)</div>
<div class="signoff-block">
  <div>
    <div class="signoff-name">Signed: {{ inspector }}</div>
    <div class="signoff-hint">Digital signature captured in Dalux Field on {{ insp_date }}</div>
  </div>
</div>

<!-- Provenance (design system §9) -->
<div class="provenance">
  Generated from Dalux Field &middot; Form ID {{ form_id }} &middot;
  Form No. {{ form_number }} &middot; Status: {{ status }} &middot; Created {{ created_display }} by {{ creator_name }} &middot; Modified {{ modified_display }} by {{ modifier_name }}
</div>

{% if all_photos %}
<div class="section-break"></div>
<div class="page-header-sm">Photographic evidence (appendix) &mdash; {{ all_photos|length }} photos</div>
{% for p in all_photos %}
<div class="photo-cell-full">
  <div class="pc-full-hdr">
    <span class="pc-full-no">Photo #{{ p.photo_no }}</span>
    <span class="pc-full-item">{{ p.item_num }} &mdash; {{ p.item_title }}</span>
    <span class="pc-src pc-src-{{ p.src }}">{{ 'CAR evidence' if p.src == 'evidence' else 'Inspection' }}</span>
  </div>
  <div class="pc-full-img">
    {% if p.local_src %}<img src="{{ p.local_src }}" alt="Photo #{{ p.photo_no }}"><div class="ph-no">#{{ p.photo_no }}</div>
    {% else %}<div class="photo-missing-large">Photo #{{ p.photo_no }} &mdash; not downloaded</div>{% endif %}
  </div>
  <div class="pc-full-meta">Captured {{ p.created or '—' }}</div>
</div>
{% endfor %}
{% endif %}

</body>
</html>
