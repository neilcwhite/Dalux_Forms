/* =====================================================================
   Spencer Dalux Report Design System v1.0 — shared CSS partial
   =====================================================================
   Single source of truth for tokens, page setup, and shared components.
   Every report template includes this partial at the top of its <style>
   block and only defines template-specific CSS below.

   See docs/template_design_system_v1.md for the canonical spec.
   ===================================================================== */

/* ---------- Tokens (colours) ----------
   These are the ONLY colours allowed in any template. No locally-defined
   surface or accent colours. If a template appears to need a new colour,
   raise in chat — don't introduce one locally. */
:root {
  --spencer-blue:  #233E99;  /* Primary brand — section bands, box edges, title */
  --ok-green:      #2E7D4F;  /* Positive / closed / Yes / Green */
  --err-red:       #C0392B;  /* Negative / expired / No / Red */
  --na-grey:       #8A8A8A;  /* Not applicable / neutral */
  --amber:         #B26500;  /* Open-but-still-valid / data quality warning */
  --text:          #1A1A1A;  /* Primary body text */
  --text-muted:    #555;     /* Labels, captions, footer */
  --bg-alt:        #FAFBFD;  /* Panel / alternating row backgrounds */
  --divider:       #233E99;  /* Structural borders (Spencer Blue) */
  --divider-soft:  #D8DCE6;  /* Soft row dividers and horizontal rules */
}

/* ---------- Page setup ---------- */
@page {
  size: A4;
  margin: 10mm 10mm 15mm 10mm;

  @bottom-left {
    content: element(pageFooter);
    font-family: "Calibri", "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 7.5pt;
    color: var(--text-muted);
    width: 100%;
  }
}

/* ---------- Base typography ---------- */
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: "Calibri", "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
  color: var(--text);
  font-size: 9.5pt;
  line-height: 1.4;
}

/* ---------- Running page footer ----------
   Renders on every page via CSS running element. Two-column layout:
   left stacks Dalux Field / Form No. / Issue No. / Rev. date and SOS
   location; right stacks the modifier email above "Page N of M". */
.page-footer {
  position: running(pageFooter);
  border-top: 1px solid var(--divider-soft);
  padding-top: 4pt;
  font-size: 7.5pt;
  color: var(--text-muted);
  line-height: 1.3;
}
/* Use table layout rather than flex — WeasyPrint's flex support inside
   running elements can drop block-level children silently. Table-cell is
   deterministic and gives us the same visual two-column split. */
.page-footer .row {
  display: table;
  width: 100%;
  table-layout: fixed;
}
.page-footer .left {
  display: table-cell;
  vertical-align: top;
}
.page-footer .right {
  display: table-cell;
  vertical-align: top;
  text-align: right;
  white-space: nowrap;
  width: 220pt;
}
.page-footer .email { color: var(--text); }
.page-footer .pageno::before {
  content: "Page " counter(page) " of " counter(pages);
}
.page-footer .line1 { font-weight: 600; color: var(--text); }

/* ---------- Document header band (page 1) ---------- */
.header-band {
  display: table;
  width: 100%;
  margin-bottom: 8pt;
}
.header-band .cell {
  display: table-cell;
  vertical-align: middle;
}
.qr-cell { width: 62px; }
.qr-cell img { display: block; width: 62px; height: 62px; }
.title-cell { padding: 0 12pt; text-align: center; }
.title-cell .doc-title {
  font-size: 13pt;
  font-weight: 700;
  color: var(--spencer-blue);
  letter-spacing: 0.2px;
  margin: 0;
  line-height: 1.2;
  white-space: nowrap;
}
.logo-cell { width: 160px; text-align: right; }
.logo-cell img {
  display: inline-block;
  height: 40px;
  width: auto;
}

/* ---------- Identifier grid ----------
   20% / 60% / 20% column layout with Project no. locked to cell (1,1). */
.id-grid {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  margin-bottom: 10pt;
  table-layout: fixed;
}
.id-grid td {
  background: var(--bg-alt);
  border: 1px solid var(--divider);
  padding: 5pt 8pt;
  vertical-align: top;
  overflow-wrap: break-word;
}
.id-grid td:nth-child(1) { width: 20%; }
.id-grid td:nth-child(2) { width: 60%; }
.id-grid td:nth-child(3) { width: 20%; }
.id-grid td + td { border-left: none; }
.id-grid tr + tr td { border-top: none; }
.id-label {
  font-size: 6.5pt;
  letter-spacing: 0.4px;
  color: var(--text-muted);
  margin-bottom: 1pt;
}
.id-value {
  font-size: 10.5pt;
  font-weight: 600;
  color: var(--text);
  line-height: 1.1;
}

/* Auto-shrink tiers — applied by the builder's size_class() based on content
   length. Calibrated for A4 with 20/60/20 grid and 10.5pt base. */
.id-value.len-md { font-size: 9.5pt; line-height: 1.15; }
.id-value.len-lg { font-size: 8.5pt; line-height: 1.20; }
.id-value.len-xl { font-size: 7.5pt; line-height: 1.25; }

/* "mono" is a size-hint modifier, NOT a font-family change. Design system
   rule #1: one font family throughout. The Calibri stack stays. */
.id-value.mono { font-size: 9.5pt; }
.id-value.mono.len-md { font-size: 8.5pt; }
.id-value.mono.len-lg { font-size: 7.5pt; }
.id-value.mono.len-xl { font-size: 6.5pt; }

/* ---------- Status chip ---------- */
.status-chip {
  display: inline-block;
  padding: 2pt 8pt;
  border-radius: 10pt;
  font-size: 8.5pt;
  font-weight: 700;
  letter-spacing: 0.5px;
  color: #fff;
}
.status-chip.closed  { background: var(--ok-green); }
.status-chip.open    { background: var(--amber); }
.status-chip.expired { background: var(--err-red); }

/* ---------- Validity block (permit-only component) ---------- */
.validity-block {
  margin-bottom: 12pt;
  border: 1.5pt solid var(--spencer-blue);
  border-radius: 2pt;
  overflow: hidden;
}
.validity-head {
  background: var(--spencer-blue);
  color: #fff;
  padding: 4pt 10pt;
  font-size: 9pt;
  font-weight: 700;
  letter-spacing: 0.7px;
}
.validity-head .tz-note {
  float: right;
  font-weight: 400;
  font-size: 7.5pt;
  color: rgba(255,255,255,0.80);
  letter-spacing: 0.3px;
  text-transform: none;
}
.validity-body {
  display: table;
  width: 100%;
  table-layout: fixed;
}
.validity-body .v-cell {
  display: table-cell;
  padding: 8pt 12pt;
  vertical-align: middle;
  border-right: 1px solid var(--divider);
}
.validity-body .v-cell:last-child { border-right: none; }
.validity-body .v-label {
  font-size: 7pt;
  color: var(--text-muted);
  letter-spacing: 0.4px;
}
.validity-body .v-value {
  font-size: 11pt;
  font-weight: 700;
  color: var(--text);
  margin-top: 2pt;
  white-space: nowrap;
}
.validity-body .v-value .tz {
  font-weight: 700;
  color: var(--text);
  margin-left: 4pt;
  font-size: 11pt;
}
.validity-body .v-duration {
  text-align: center;
  width: 110pt;
}

/* ---------- Section header + body ---------- */
.section {
  margin-top: 10pt;
  margin-bottom: 8pt;
  page-break-inside: avoid;
}
.section-head {
  background: var(--spencer-blue);
  color: #fff;
  padding: 4pt 10pt;
  font-size: 9pt;
  font-weight: 700;
  letter-spacing: 0.7px;
}
.section-head .sub {
  font-weight: 400;
  font-size: 7.5pt;
  color: rgba(255,255,255,0.80);
  margin-left: 8pt;
  letter-spacing: 0.3px;
  text-transform: none;
}
.section-body {
  border: 1px solid var(--divider);
  border-top: none;
  padding: 8pt 10pt;
  background: #fff;
}
.section-body.no-pad { padding: 0; }

/* ---------- Signature block ---------- */
.sig-block {
  display: table;
  width: 100%;
  border-collapse: collapse;
}
.sig-block .sig-cell {
  display: table-cell;
  vertical-align: top;
  padding: 0;
}
.sig-block .sig-left { width: 220px; padding-right: 14pt; }
.sig-block .sig-right { vertical-align: top; padding-top: 4pt; }

/* Placeholder signature box — used when no attachment is available. */
.sig-img {
  width: 220px;
  height: 75px;
  border: 1px dashed #B5BCCB;
  background: linear-gradient(135deg, #fafbfd 25%, transparent 25%) -8px 0/16px 16px,
              linear-gradient(225deg, #fafbfd 25%, transparent 25%) -8px 0/16px 16px,
              linear-gradient(315deg, #fafbfd 25%, transparent 25%) 0 0/16px 16px,
              linear-gradient(45deg, #fafbfd 25%, #ffffff 25%) 0 0/16px 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9AA0AE;
  font-size: 7pt;
  letter-spacing: 0.6px;
}
.sig-img .missing-note {
  font-size: 7pt;
  letter-spacing: 0.4px;
  color: #9AA0AE;
}

/* Real signature — rendered when attachment fetched. */
.sig-img-real {
  width: 220px;
  height: 75px;
  object-fit: contain;
  object-position: left center;
  border-bottom: 1px solid var(--divider-soft);
}

.sig-caption {
  margin-top: 4pt;
  font-size: 8.5pt;
  color: var(--text);
}
.sig-caption .name { font-weight: 700; }
.sig-caption .ts {
  color: var(--text-muted);
  font-size: 7.5pt;
  margin-top: 1pt;
}
.sig-role {
  font-size: 6.5pt;
  color: var(--text-muted);
  letter-spacing: 0.4px;
  margin-bottom: 3pt;
}
.sig-body {
  font-size: 8.5pt;
  color: var(--text-muted);
  line-height: 1.45;
  max-width: 360px;
}

/* ---------- Narrative table (labelled content) ---------- */
.narrative-table {
  width: 100%;
  border-collapse: collapse;
}
.narrative-table td {
  border: 1px solid var(--divider);
  padding: 6pt 9pt;
  vertical-align: top;
}
.narrative-table td.label {
  width: 170px;
  background: var(--bg-alt);
  font-size: 7.5pt;
  color: var(--text-muted);
  letter-spacing: 0.3px;
}
.narrative-table td.content {
  font-size: 9.5pt;
  color: var(--text);
  font-weight: 500;
}

/* ---------- State pills (Yes / No / N/A / Blank) ---------- */
.state-pill {
  display: inline-block;
  padding: 2pt 8pt;
  font-size: 8pt;
  font-weight: 700;
  letter-spacing: 0.6px;
  min-width: 52px;
  text-align: center;
  border-radius: 2pt;
  color: #fff;
}
.state-pill.yes { background: var(--ok-green); }
.state-pill.no  { background: var(--err-red); }
.state-pill.na  { background: var(--na-grey); }
.state-pill.blank {
  background: transparent;
  color: var(--text-muted);
  border: 1px dashed var(--na-grey);
}

/* ---------- Data quality banner ---------- */
.dq-banner {
  border: 1px solid var(--amber);
  background: #FFF3E0;
  padding: 7pt 10pt;
  margin: 8pt 0;
}
.dq-title {
  font-size: 8pt;
  font-weight: 700;
  color: var(--amber);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 3pt;
}
.dq-banner ul {
  margin: 0;
  padding-left: 18pt;
  font-size: 8.5pt;
  line-height: 1.45;
}

/* ---------- Provenance line ---------- */
.provenance {
  margin-top: 12pt;
  padding-top: 6pt;
  border-top: 1px solid var(--divider-soft);
  text-align: center;
  font-size: 7.5pt;
  font-style: italic;
  color: var(--text-muted);
}
