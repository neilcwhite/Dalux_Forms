# Copy this file to .env and fill in real values.
# .env is gitignored; never commit it.
# Restrict file permissions on the server: chmod 600 backend/.env

# --- MariaDB connection (read-only from this app's perspective) ---
DB_HOST=DBHUB.cspencerltd.co.uk
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=SHEQ

# --- Dalux API ---
# Used by the report builders to download attachment photos on demand.
DALUX_API_KEY=
DALUX_BASE_URL=https://node2.field.dalux.com/service/api

# --- App config ---
APP_NAME=Dalux Report Portal
# Set DEBUG=false in production to quieten SQL logs.
DEBUG=false
# The public URL colleagues use to reach the app. Used to build the
# "Download PDF" links in Teams notification cards.
APP_PUBLIC_URL=http://dalux-forms.cspencerltd.co.uk

# --- Teams notifications (Power Automate HTTP trigger) ---
# Full Power Automate URL incl. SAS signature. Treat as a secret.
# Leave blank to disable the feature; the scheduler will still start but
# notifications will short-circuit out.
NOTIFY_POWER_AUTOMATE_URL=
# Master kill-switch. Set to true after running the bootstrap backfill.
NOTIFY_ENABLED=false

# --- Template upload feature ---
# Strong random string (e.g. `openssl rand -hex 32`). Required header on
# the /api/admin/templates/upload endpoint. Empty/unset = feature disabled
# (endpoint returns 503).
ADMIN_UPLOAD_TOKEN=

# --- SharePoint upload (closed-form PDFs) ---
# Auth via Azure AD app registration (client credentials flow). Currently
# reusing the n8n app reg as a stop-gap; IT will issue a dedicated reg with
# Sites.Selected scoped to the target folder later.
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# Destination — the folder must already exist; the app does not create it.
SHAREPOINT_HOSTNAME=spencergrouphull.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/DALUXSetup-DaluxFormNotifications
SHAREPOINT_FOLDER_PATH=/01 New Documents

# --- Login (stop-gap before Azure Entra) ---
# Comma-separated emails seeded as 'admin' on first startup if the
# approved_users table is empty. Each gets INITIAL_ADMIN_PASSWORD; users
# change their own password after first sign-in.
INITIAL_ADMIN_EMAILS=neil.white@thespencergroup.co.uk,claire.ransom@thespencergroup.co.uk
INITIAL_ADMIN_PASSWORD=Dalux
